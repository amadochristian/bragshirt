# ==============================================================
# VARIÁVEIS DE AMBIENTE — só para o servidor (Vercel Functions)
# ==============================================================
# O browser NÃO lê este arquivo.
# Configure estas variáveis em: Vercel → Settings → Environment Variables
#
# As chaves do Supabase (URL e anon key) ficam em js/config.js
# porque são públicas. Só a service_role key vai aqui.
# ==============================================================

# Supabase — chave de serviço (acesso total ao banco, só no servidor)
SUPABASE_SERVICE_KEY=eyJ...

# Mercado Pago — token de acesso
# Encontre em: mercadopago.com.br → Developers → Credenciais
MP_ACCESS_TOKEN=APP_USR-xxxx

# Melhor Envio — token de API
# Encontre em: melhorenvio.com.br → Minha Conta → Tokens
MELHOR_ENVIO_TOKEN=eyJ...

# Resend — envio de e-mails
# Encontre em: resend.com → API Keys
RESEND_API_KEY=re_xxxx

# CEP de origem da loja (para cálculo de frete)
CEP_ORIGEM=12900000
